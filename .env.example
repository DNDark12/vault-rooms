# 127.0.0.1 only accepts connections from this machine. Other LAN machines
# cannot reach 127.0.0.1 (it always means "this computer" to them, no matter
# whose it is) and editing /etc/hosts does not change that. To let teammates
# on the same LAN connect, set HOST=0.0.0.0 to bind all interfaces, then
# share the printed "LAN:" URL / invite link (uses your real LAN IP) instead
# of the "Local:" one.
HOST=0.0.0.0
# PORT=8787
MAX_FILE_BYTES=5242880
ALLOW_REMOTE_BOOTSTRAP=false

# Plain HTTP is for development or a trusted reverse-proxy hop only.
TLS_MODE=plain
HOST=0.0.0.0
# PORT=8787
# PUBLIC_URL=https://relay.example.test
MAX_FILE_BYTES=5242880
ALLOW_REMOTE_BOOTSTRAP=false

# Self-managed pinned TLS for LAN deployments.
# TLS_MODE=pinned
# TLS_PORT=8788
# IDENTITY_DIR=data
# Fresh pinned servers must keep this false. For an already-bootstrapped legacy server, set true
# to enter dual-stack migration; after clients migrate, restart with false to durably enforce TLS.
# TLS_DUAL_STACK=false
# TLS_MIGRATION_MODE=non_strict

# OS-trusted certificate files for a standalone HTTPS listener.
# TLS_MODE=os-trusted
# TLS_CERT_FILE=/run/secrets/tls-cert.pem
# TLS_KEY_FILE=/run/secrets/tls-key.pem
